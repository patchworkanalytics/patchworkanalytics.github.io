---
import { getCollection } from 'astro:content'
import SidebarLayout from '../../../layouts/SidebarLayout.astro'

const base = import.meta.env.BASE_URL

const posts = await getCollection('blog', ({ data }) => !data.draft)

// Build a map of tag → post count
const tagCounts = new Map<string, number>()
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}

// Sort alphabetically
const tags = [...tagCounts.entries()].sort(([a], [b]) => a.localeCompare(b))

function tagSlug(tag: string) {
  return tag.toLowerCase().replace(/\s+/g, '-')
}
---

<SidebarLayout title="Tags — Blog" description="Browse blog posts by tag.">
  <main class="section-padding">
    <div class="container-max">
      <a
        href={`${base}blog`}
        class="inline-flex items-center gap-2 text-text-muted hover:text-interactive transition-colors text-body mb-10"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
          ></path>
        </svg>
        All posts
      </a>

      <div class="mb-12">
        <p class="text-interactive font-mono text-eyebrow uppercase tracking-widest mb-3">
          Browse by topic
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-text-primary">Tags</h1>
      </div>

      {tags.length === 0 && <p class="text-text-muted">No tags yet.</p>}

      <ul class="flex flex-wrap gap-3">
        {
          tags.map(([tag, count]) => (
            <li>
              <a
                href={`${base}blog/tags/${tagSlug(tag)}`}
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-surface-border bg-surface-muted hover:border-interactive hover:text-interactive transition-colors text-body text-text-secondary font-mono"
              >
                {tag}
                <span class="text-label text-text-muted">{count}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</SidebarLayout>
