---
import { getCollection } from 'astro:content'
import { blogSettings } from '../config'

if (!blogSettings.homeShowBlogPosts) return

const base = import.meta.env.BASE_URL

const posts = await getCollection('blog', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const recent = posts.slice(0, blogSettings.homePostsToShow)

if (recent.length === 0) return
---

<section class="section-padding border-t border-surface-border">
  <div class="container-max">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <p class="text-interactive font-mono text-eyebrow uppercase tracking-widest mb-3">Writing</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary">Recent Posts</h2>
      </div>
      <a
        href={`${base}blog`}
        class="text-body text-text-muted hover:text-interactive transition-colors font-mono"
        >All posts →</a
      >
    </div>

    <ul class="space-y-6">
      {
        recent.map((post) => {
          const slug = post.id.replace(/\.md$/, '')
          return (
            <li>
              <a href={`${base}blog/${slug}`} class="group block">
                <article class="rounded-xl border border-surface-border bg-surface-muted p-6 hover:border-interactive transition-colors">
                  <time class="text-text-muted font-mono text-label">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      timeZone: 'UTC',
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <h3 class="text-xl font-semibold text-text-primary mt-2 mb-2 group-hover:text-interactive transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-text-secondary text-body leading-relaxed">
                    {post.data.description}
                  </p>
                  {post.data.tags && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {post.data.tags.map((tag) => (
                        <a
                          href={`${base}blog/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                          class="px-2 py-1 rounded text-label font-mono text-interactive bg-interactive/10 hover:bg-interactive/20 transition-colors"
                          onclick="event.stopPropagation()"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </article>
              </a>
            </li>
          )
        })
      }
    </ul>
  </div>
</section>
